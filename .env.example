# Hevy API key — requires Hevy Pro. Get it at https://hevy.com/settings?developer
HEVY_API_KEY=

# Anthropic API key
ANTHROPIC_API_KEY=

# When true, Hevy WRITE calls are logged (resolved payload) and NOT sent to Hevy.
# Reads and sync still hit the real Hevy API. Keep true until you've verified the flow.
DRY_RUN=true

# Optional overrides
# ANTHROPIC_MODEL=claude-opus-4-8
# DATABASE_URL=sqlite:///./repmind.db
# STALL_LOOKBACK_SESSIONS=4
# CORS_ORIGINS=http://localhost:5173
